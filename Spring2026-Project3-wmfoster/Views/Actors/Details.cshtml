@model Spring2026_Project3_wmfoster.ViewModels.ActorDetailsViewModel

<h1>@Model.Actor.Name</h1>

<p><strong>Gender:</strong> @Model.Actor.Gender</p>
<p><strong>Age:</strong> @Model.Actor.Age</p>
<p><strong>IMDB:</strong> <a href="@Model.Actor.ImdbLink" target="_blank">Link</a></p>

<h3>Movies</h3>
<ul>
    @foreach (var movie in Model.Movies)
    {
        <li>@movie</li>
    }
</ul>

<h3>AI Tweets</h3>
<ul>
    @foreach (var tweet in Model.Tweets)
    {
        <li>
            @tweet.Tweet <br />
            <strong>Sentiment:</strong> @tweet.Sentiment
        </li>
    }
</ul>

<p><strong>Overall Sentiment:</strong> @Model.OverallSentiment</p>