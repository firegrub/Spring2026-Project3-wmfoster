@model Spring2026_Project3_wmfoster.ViewModels.MovieDetailsViewModel

<h1>@Model.Movie.Title</h1>

<p><strong>Genre:</strong> @Model.Movie.Genre</p>
<p><strong>Year:</strong> @Model.Movie.YearOfRelease</p>
<p><strong>IMDB:</strong> <a href="@Model.Movie.ImdbLink" target="_blank">Link</a></p>

<h3>Actors</h3>
<ul>
    @foreach (var actor in Model.Actors)
    {
        <li>@actor</li>
    }
</ul>

<h3>AI Reviews</h3>
<ul>
    @foreach (var review in Model.Reviews)
    {
        <li>
            @review.Review <br />
            <strong>Sentiment:</strong> @review.Sentiment
        </li>
    }
</ul>

<p><strong>Average Sentiment:</strong> @Model.AverageSentiment</p>